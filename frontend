<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DAO Proposal Risk Scorer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ── reset & tokens ─────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --white:   #FFFFFF;
  --off:     #F7F7F5;
  --gray100: #F3F4F6;
  --gray200: #E5E7EB;
  --gray300: #D1D5DB;
  --gray400: #9CA3AF;
  --gray500: #6B7280;
  --gray700: #374151;
  --gray900: #111827;
  --black:   #0A0A0A;
  --ink:     #0D0D0D;

  --risk-hi:  #DC2626;
  --risk-mid: #D97706;
  --risk-lo:  #16A34A;
  --accept:   #16A34A;
  --revise:   #D97706;
  --reject:   #DC2626;

  --sidebar-bg: #0D0D0D;
  --sidebar-border: #1F1F1F;

  --syne: 'Syne', sans-serif;
  --inter: 'Inter', sans-serif;
  --mono: 'JetBrains Mono', monospace;

  --radius: 8px;
  --radius-sm: 4px;
  --sidebar-w: 280px;
  --header-h: 60px;
}

html { scroll-behavior: smooth; }
body {
  background: var(--white);
  color: var(--ink);
  font-family: var(--inter);
  font-size: 14px;
  line-height: 1.6;
  min-height: 100vh;
}

/* ── layout ────────────────────────────────────────────────────────────── */
.app {
  display: grid;
  grid-template-columns: var(--sidebar-w) 1fr;
  grid-template-rows: var(--header-h) 1fr;
  min-height: 100vh;
}

/* ── header ─────────────────────────────────────────────────────────────── */
.header {
  grid-column: 1 / -1;
  background: var(--black);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28px;
  border-bottom: 1px solid #1a1a1a;
  position: sticky;
  top: 0;
  z-index: 50;
}

.logo {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: var(--syne);
  font-weight: 800;
  font-size: 15px;
  color: var(--white);
  letter-spacing: -0.01em;
}

.logo-icon {
  width: 32px; height: 32px;
  background: var(--white);
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}

.header-chips {
  display: flex;
  align-items: center;
  gap: 10px;
}

.chip {
  font-size: 11px;
  font-family: var(--mono);
  padding: 4px 10px;
  border-radius: 100px;
  letter-spacing: 0.04em;
}

.chip-outline {
  border: 1px solid #2a2a2a;
  color: #666;
}

.chip-live {
  border: 1px solid #2d4a2d;
  color: #4ade80;
  background: #0d1a0d;
  display: flex;
  align-items: center;
  gap: 6px;
}

.pulse {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #4ade80;
  animation: pulse 2s infinite;
}

@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.8)} }

/* ── sidebar ──────────────────────────────────────────────────────────── */
.sidebar {
  background: var(--sidebar-bg);
  border-right: 1px solid var(--sidebar-border);
  height: calc(100vh - var(--header-h));
  overflow-y: auto;
  position: sticky;
  top: var(--header-h);
  display: flex;
  flex-direction: column;
  padding: 24px 0;
}

.sidebar-section {
  padding: 0 16px;
  margin-bottom: 28px;
}

.sidebar-label {
  font-size: 9px;
  font-family: var(--mono);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #3a3a3a;
  margin-bottom: 10px;
  padding: 0 8px;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 9px 10px;
  border: none;
  background: transparent;
  color: #555;
  font-family: var(--inter);
  font-size: 13px;
  text-align: left;
  cursor: pointer;
  border-radius: var(--radius-sm);
  transition: background .15s, color .15s;
  letter-spacing: 0.01em;
  margin-bottom: 1px;
}

.nav-item:hover { background: #161616; color: #aaa; }
.nav-item.active { background: #1a1a1a; color: var(--white); }

.nav-item .icon { width: 18px; text-align: center; font-size: 13px; }
.nav-item .badge {
  margin-left: auto;
  font-size: 9px;
  font-family: var(--mono);
  color: #333;
  font-weight: 600;
}

/* stats widget */
.stats-widget {
  margin-top: auto;
  padding: 16px;
  border-top: 1px solid var(--sidebar-border);
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.stat-cell {
  background: #111;
  border: 1px solid #1e1e1e;
  border-radius: var(--radius-sm);
  padding: 10px 12px;
}

.stat-num {
  font-family: var(--syne);
  font-size: 20px;
  font-weight: 700;
  color: var(--white);
  line-height: 1;
  margin-bottom: 3px;
}

.stat-lbl {
  font-size: 9px;
  font-family: var(--mono);
  color: #444;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.stat-cell.span2 { grid-column: 1/-1; }

/* proposal history in sidebar */
.history-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: background .12s;
  margin-bottom: 2px;
}

.history-item:hover { background: #111; }

.history-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  margin-top: 6px;
  flex-shrink: 0;
}

.history-dot.ACCEPT { background: var(--accept); }
.history-dot.REVISE { background: var(--revise); }
.history-dot.REJECT { background: var(--reject); }

.history-title {
  font-size: 12px;
  color: #888;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 180px;
}

.history-meta {
  font-size: 10px;
  color: #444;
  font-family: var(--mono);
  margin-top: 2px;
}

/* ── main ─────────────────────────────────────────────────────────────── */
.main {
  height: calc(100vh - var(--header-h));
  overflow-y: auto;
}

.panel {
  display: none;
  padding: 36px 48px;
  max-width: 900px;
  animation: fadeIn .2s ease;
}
.panel.active { display: block; }

@keyframes fadeIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:none} }

/* ── section heading ───────────────────────────────────────────────────── */
.panel-heading {
  margin-bottom: 32px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--gray200);
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24px;
}

.panel-title {
  font-family: var(--syne);
  font-size: 26px;
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--ink);
  line-height: 1.1;
  margin-bottom: 5px;
}

.panel-sub {
  font-size: 13px;
  color: var(--gray500);
}

.panel-num {
  font-family: var(--syne);
  font-size: 64px;
  font-weight: 800;
  color: var(--gray100);
  line-height: 1;
  letter-spacing: -0.04em;
  user-select: none;
  flex-shrink: 0;
}

/* ── form ───────────────────────────────────────────────────────────────── */
.field-group {
  margin-bottom: 18px;
}

.field-label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gray500);
  margin-bottom: 7px;
}

.field-input,
.field-textarea {
  width: 100%;
  background: var(--white);
  border: 1.5px solid var(--gray200);
  border-radius: var(--radius);
  padding: 11px 14px;
  font-family: var(--inter);
  font-size: 14px;
  color: var(--ink);
  outline: none;
  transition: border-color .15s, box-shadow .15s;
}

.field-input:focus,
.field-textarea:focus {
  border-color: var(--gray400);
  box-shadow: 0 0 0 3px rgba(0,0,0,.06);
}

.field-textarea {
  resize: vertical;
  min-height: 120px;
  line-height: 1.6;
}

.field-hint {
  font-size: 11px;
  color: var(--gray400);
  margin-top: 5px;
}

.field-count {
  font-size: 11px;
  color: var(--gray400);
  text-align: right;
  margin-top: 4px;
  font-family: var(--mono);
}

/* ── buttons ────────────────────────────────────────────────────────────── */
.btn-row { display: flex; gap: 10px; margin-top: 24px; flex-wrap: wrap; }

.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  border-radius: var(--radius);
  font-family: var(--syne);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  cursor: pointer;
  border: none;
  transition: all .15s;
}

.btn-primary {
  background: var(--black);
  color: var(--white);
}
.btn-primary:hover { background: #222; }
.btn-primary:disabled { opacity: .4; cursor: not-allowed; }

.btn-ghost {
  background: transparent;
  color: var(--gray500);
  border: 1.5px solid var(--gray200);
}
.btn-ghost:hover { border-color: var(--gray400); color: var(--ink); }

/* ── score rings ─────────────────────────────────────────────────────── */
.result-section {
  display: none;
  margin-top: 36px;
  animation: fadeIn .4s ease;
}
.result-section.show { display: block; }

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--gray200);
}

.result-pid {
  font-family: var(--mono);
  font-size: 12px;
  color: var(--gray400);
  margin-bottom: 4px;
}

.result-title {
  font-family: var(--syne);
  font-size: 20px;
  font-weight: 700;
  color: var(--ink);
}

.rec-badge {
  font-family: var(--syne);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.06em;
  padding: 8px 20px;
  border-radius: 100px;
  text-transform: uppercase;
}

.rec-ACCEPT { background: #f0fdf4; color: var(--accept); border: 1.5px solid #bbf7d0; }
.rec-REVISE { background: #fffbeb; color: var(--revise); border: 1.5px solid #fde68a; }
.rec-REJECT { background: #fef2f2; color: var(--reject); border: 1.5px solid #fecaca; }

/* gauge rings */
.gauges-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16px;
  margin-bottom: 28px;
}

.gauge-card {
  background: var(--off);
  border: 1px solid var(--gray200);
  border-radius: var(--radius);
  padding: 24px 16px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.gauge-svg-wrap {
  position: relative;
  width: 100px;
  height: 60px;
  margin-bottom: 12px;
}

.gauge-svg {
  overflow: visible;
}

.gauge-track {
  fill: none;
  stroke: var(--gray200);
  stroke-width: 8;
  stroke-linecap: round;
}

.gauge-fill {
  fill: none;
  stroke-width: 8;
  stroke-linecap: round;
  stroke-dasharray: 157;
  stroke-dashoffset: 157;
  transition: stroke-dashoffset 1.2s cubic-bezier(.4,0,.2,1);
}

.gauge-val {
  position: absolute;
  bottom: -2px;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--syne);
  font-size: 22px;
  font-weight: 800;
  color: var(--ink);
  letter-spacing: -0.02em;
  line-height: 1;
}

.gauge-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--gray500);
  text-align: center;
  margin-bottom: 3px;
}

.gauge-sub {
  font-size: 11px;
  color: var(--gray400);
  text-align: center;
}

/* quorum card */
.quorum-card {
  background: var(--off);
  border: 1px solid var(--gray200);
  border-radius: var(--radius);
  padding: 20px 24px;
  display: flex;
  align-items: center;
  gap: 24px;
}

.quorum-val {
  font-family: var(--syne);
  font-size: 40px;
  font-weight: 800;
  color: var(--ink);
  line-height: 1;
  flex-shrink: 0;
}

.quorum-desc {
  font-size: 13px;
  color: var(--gray700);
  line-height: 1.5;
}

.quorum-desc strong {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 2px;
}

/* analysis block */
.analysis-block {
  margin-top: 20px;
  background: var(--off);
  border: 1px solid var(--gray200);
  border-radius: var(--radius);
  padding: 20px 24px;
}

.analysis-eyebrow {
  font-size: 9px;
  font-family: var(--mono);
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--gray400);
  margin-bottom: 8px;
}

.analysis-text {
  font-size: 14px;
  color: var(--gray700);
  line-height: 1.7;
}

.risks-benefits {
  margin-top: 20px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.rb-card {
  border: 1px solid var(--gray200);
  border-radius: var(--radius);
  padding: 18px 20px;
}

.rb-card.risks { border-left: 3px solid var(--risk-hi); }
.rb-card.benefits { border-left: 3px solid var(--risk-lo); }

.rb-title {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 12px;
}

.rb-card.risks .rb-title { color: var(--risk-hi); }
.rb-card.benefits .rb-title { color: var(--risk-lo); }

.rb-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.rb-list li {
  font-size: 13px;
  color: var(--gray700);
  line-height: 1.4;
  display: flex;
  gap: 8px;
  align-items: flex-start;
}

.rb-list li::before {
  content: "—";
  color: var(--gray300);
  flex-shrink: 0;
  margin-top: 1px;
}

/* ── in-progress indicator ───────────────────────────────────────────── */
.progress-indicator {
  display: none;
  margin: 24px 0;
  padding: 20px 24px;
  background: var(--off);
  border: 1px solid var(--gray200);
  border-radius: var(--radius);
}
.progress-indicator.show { display: block; }

.progress-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--gray700);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.spinner {
  width: 14px; height: 14px;
  border: 2px solid var(--gray200);
  border-top-color: var(--ink);
  border-radius: 50%;
  animation: spin .7s linear infinite;
}

@keyframes spin { to{ transform:rotate(360deg); } }

.progress-steps {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.progress-step {
  font-size: 11px;
  font-family: var(--mono);
  padding: 3px 10px;
  border-radius: 100px;
  background: var(--gray100);
  color: var(--gray400);
  transition: all .3s;
}

.progress-step.active {
  background: var(--ink);
  color: var(--white);
}

.progress-step.done {
  background: #f0fdf4;
  color: var(--accept);
  border: 1px solid #bbf7d0;
}

/* ── log terminal ─────────────────────────────────────────────────────── */
.log-terminal {
  display: none;
  margin-top: 16px;
  background: var(--off);
  border: 1px solid var(--gray200);
  border-radius: var(--radius);
  padding: 14px 16px;
  font-family: var(--mono);
  font-size: 11px;
  line-height: 1.8;
  max-height: 160px;
  overflow-y: auto;
}
.log-terminal.show { display: block; }

.log-line { display: flex; gap: 12px; }
.log-ts { color: var(--gray300); flex-shrink: 0; }
.log-info { color: var(--gray500); }
.log-ok   { color: #16a34a; }
.log-err  { color: #dc2626; }
.log-blue { color: #2563eb; }

/* ── proposal detail view ─────────────────────────────────────────────── */
.detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 20px;
}

.detail-cell {
  background: var(--off);
  border: 1px solid var(--gray200);
  border-radius: var(--radius);
  padding: 14px 16px;
}

.detail-key {
  font-size: 9px;
  font-family: var(--mono);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gray400);
  margin-bottom: 5px;
}

.detail-val {
  font-size: 13px;
  color: var(--gray700);
  word-break: break-all;
}

.detail-cell.span2 { grid-column: 1/-1; }

/* ── list panel ──────────────────────────────────────────────────────── */
.proposal-table {
  width: 100%;
  border-collapse: collapse;
}

.proposal-table th {
  text-align: left;
  font-size: 10px;
  font-family: var(--mono);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gray400);
  padding: 10px 14px;
  border-bottom: 1px solid var(--gray200);
}

.proposal-table td {
  padding: 12px 14px;
  border-bottom: 1px solid var(--gray100);
  font-size: 13px;
  color: var(--gray700);
  vertical-align: middle;
}

.proposal-table tr:hover td { background: var(--off); }

.table-id {
  font-family: var(--mono);
  color: var(--gray400);
}

.table-rec {
  font-size: 11px;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 100px;
  display: inline-block;
}

.table-rec.ACCEPT { background: #f0fdf4; color: var(--accept); }
.table-rec.REVISE { background: #fffbeb; color: var(--revise); }
.table-rec.REJECT { background: #fef2f2; color: var(--reject); }

.table-link {
  color: var(--gray400);
  text-decoration: none;
  font-family: var(--mono);
  font-size: 11px;
}
.table-link:hover { color: var(--ink); }

/* ── empty state ──────────────────────────────────────────────────────── */
.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: var(--gray400);
}
.empty-icon { font-size: 36px; margin-bottom: 12px; }
.empty-title {
  font-family: var(--syne);
  font-size: 16px;
  color: var(--gray500);
  margin-bottom: 6px;
}
.empty-sub { font-size: 13px; }

/* ── about panel ─────────────────────────────────────────────────────── */
.how-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 28px;
}

.how-card {
  border: 1px solid var(--gray200);
  border-radius: var(--radius);
  padding: 20px;
}

.how-step {
  font-family: var(--syne);
  font-size: 12px;
  font-weight: 700;
  color: var(--gray300);
  letter-spacing: 0.08em;
  margin-bottom: 8px;
}

.how-title {
  font-family: var(--syne);
  font-size: 15px;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 6px;
}

.how-body {
  font-size: 13px;
  color: var(--gray500);
  line-height: 1.6;
}

.quorum-table {
  width: 100%;
  margin-top: 24px;
  border-collapse: collapse;
}
.quorum-table th, .quorum-table td {
  padding: 10px 14px;
  text-align: left;
  border-bottom: 1px solid var(--gray100);
  font-size: 13px;
}
.quorum-table th {
  font-size: 10px;
  font-family: var(--mono);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gray400);
}

/* ── scrollbar ────────────────────────────────────────────────────────── */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--gray200); border-radius: 2px; }

@media (max-width: 800px) {
  .app { grid-template-columns: 1fr; }
  .sidebar { display: none; }
  .panel { padding: 24px 20px; }
  .how-grid, .risks-benefits, .gauges-row { grid-template-columns: 1fr; }
}
</style>
</head>
<body>
<div class="app">

  <!-- HEADER -->
  <header class="header">
    <div class="logo">
      <div class="logo-icon">⚖</div>
      DAO Risk Scorer
    </div>
    <div class="header-chips">
      <span class="chip chip-outline">GenLayer</span>
      <span class="chip chip-outline" style="font-family:var(--mono)">Intelligent Contract</span>
      <span class="chip chip-live"><span class="pulse"></span>Studionet</span>
    </div>
  </header>

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-section">
      <div class="sidebar-label">Navigate</div>
      <button class="nav-item active" onclick="nav('submit',this)">
        <span class="icon">＋</span>Submit Proposal
        <span class="badge">01</span>
      </button>
      <button class="nav-item" onclick="nav('history',this)">
        <span class="icon">≡</span>All Proposals
