<script type="importmap">
{
  "imports": {
    "genlayer":       "https://esm.sh/genlayer-js@latest?bundle&deps=viem@2.21.54",
    "genlayer/chains":"https://esm.sh/genlayer-js@latest/chains?bundle&deps=viem@2.21.54"
