<script type="module">
import { createClient, createAccount, generatePrivateKey } from 'genlayer';
import { studionet } from 'genlayer/chains';

// ── CONFIG — replace with your deployed contract address ──────────────────
const CONTRACT_ADDRESS = '0x95032a87a392a47B906522886a0488384ca03bFD';

// ── SDK account (no wallet needed) ───────────────────────────────────────
function loadOrCreate(key) {
  let pk = localStorage.getItem(key);
  if (!pk) { pk = generatePrivateKey(); localStorage.setItem(key, pk); }
  return pk;
}

const account = createAccount(loadOrCreate('dao_scorer_pk'));
let glClient  = null;

async function client() {
  if (!glClient) {
    glClient = createClient({ chain: studionet, account });
  }
  return glClient;
}

// ── helpers ───────────────────────────────────────────────────────────────
function ts() {
  return new Date().toLocaleTimeString('en', { hour12:false, hour:'2-digit', minute:'2-digit', second:'2-digit' });
}

function log(id, msg, type='info') {
  const el = document.getElementById(id);
  if (!el) return;
  el.classList.add('show');
  const div = document.createElement('div');
  div.className = 'log-line';
  div.innerHTML = `<span class="log-ts">${ts()}</span><span class="log-${type}">${msg}</span>`;
  el.appendChild(div);
  el.scrollTop = el.scrollHeight;
}

async function readContract(method, args=[]) {
  const c = await client();
  return await c.readContract({ address: CONTRACT_ADDRESS, functionName: method, args });
}

async function writeContract(method, args=[], value=undefined) {
  const c = await client();
  const hash = await c.writeContract({ address: CONTRACT_ADDRESS, functionName: method, args, value });
  return await c.waitForTransactionReceipt({ hash, status:'FINALIZED', retries:200, interval:10000 });
}

// ── nav ───────────────────────────────────────────────────────────────────
window.nav = function(name, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  btn.classList.add('active');
  if (name === 'history') loadHistory();
};

// ── char counter ──────────────────────────────────────────────────────────
window.countChars = function(inputId, countId, min, max) {
  const el   = document.getElementById(inputId);
  const cnt  = document.getElementById(countId);
  const len  = el.value.length;
  cnt.textContent = len;
  cnt.style.color = len < min || len > max ? 'var(--risk-hi)' : 'var(--gray400)';
};

// ── score gauge animation ─────────────────────────────────────────────────
function animateGauge(fillId, valId, subId, score, colorHi, colorLo) {
  const fill = document.getElementById(fillId);
  const valEl = document.getElementById(valId);
  const sub   = document.getElementById(subId);

  // arc length is 157 (half circle r=40 * π)
  const offset = 157 - (score / 100) * 157;
  fill.style.strokeDashoffset = offset;

  // color based on score (for risk: high=red, low=green; for benefit: high=green, low=red)
  const pct = score / 100;
  let r, g, b;
  if (colorHi === 'risk') {
    // red (high) → amber (mid) → green (low)
    if (score >= 70) { fill.style.stroke = 'var(--risk-hi)'; }
    else if (score >= 40) { fill.style.stroke = 'var(--risk-mid)'; }
    else { fill.style.stroke = 'var(--risk-lo)'; }
  } else {
    // green (high) → amber (mid) → red (low)
    if (score >= 70) { fill.style.stroke = 'var(--risk-lo)'; }
    else if (score >= 40) { fill.style.stroke = 'var(--risk-mid)'; }
    else { fill.style.stroke = 'var(--risk-hi)'; }
  }

  // count-up animation
  let current = 0;
  const step = Math.ceil(score / 40);
  const iv = setInterval(() => {
    current = Math.min(current + step, score);
    valEl.textContent = current;
    if (current >= score) clearInterval(iv);
  }, 30);

  // label
  if (colorHi === 'risk') {
    sub.textContent = score >= 70 ? 'High risk' : score >= 40 ? 'Medium risk' : 'Low risk';
  } else {
    sub.textContent = score >= 70 ? 'High benefit' : score >= 40 ? 'Medium benefit' : 'Low benefit';
  }
}

// ── progress steps ────────────────────────────────────────────────────────
let progressTimer = null;
function startProgress() {
  document.getElementById('progress').classList.add('show');
  const steps = ['ps-1','ps-2','ps-3','ps-4','ps-5'];
  let i = 0;
  steps.forEach(s => { document.getElementById(s).className = 'progress-step'; });
  document.getElementById(steps[0]).classList.add('active');
  progressTimer = setInterval(() => {
    if (i > 0) document.getElementById(steps[i-1]).classList.replace('active','done');
    i++;
    if (i < steps.length) document.getElementById(steps[i]).classList.add('active');
    else clearInterval(progressTimer);
  }, 6000);
}

function endProgress() {
  clearInterval(progressTimer);
  ['ps-1','ps-2','ps-3','ps-4','ps-5'].forEach(s => {
    document.getElementById(s).className = 'progress-step done';
  });
  setTimeout(() => {
    document.getElementById('progress').classList.remove('show');
    ['ps-1','ps-2','ps-3','ps-4','ps-5'].forEach(s => {
      document.getElementById(s).className = 'progress-step';
    });
  }, 1000);
}

// ── render result ─────────────────────────────────────────────────────────
function renderResult(data) {
  document.getElementById('res-pid').textContent   = data.id;
  document.getElementById('res-title').textContent = data.title;
  document.getElementById('res-analysis').textContent = data.analysis || '—';

  const rec = data.recommendation || 'REVISE';
  const recEl = document.getElementById('res-rec');
  recEl.textContent = rec;
  recEl.className   = 'rec-badge rec-' + rec;

  // gauges
  animateGauge('g-risk-fill',    'g-risk-val',    'g-risk-sub',    data.risk_score,    'risk');
  animateGauge('g-benefit-fill', 'g-benefit-val', 'g-benefit-sub', data.benefit_score, 'benefit');

  document.getElementById('g-quorum-val').textContent = data.required_quorum + '%';
  document.getElementById('g-quorum-sub').textContent =
    data.risk_score >= 70 ? 'High-risk threshold' :
    data.risk_score >= 40 ? 'Medium-risk threshold' : 'Standard threshold';

  // risks & benefits
  let risks = [], benefits = [];
  try { risks    = JSON.parse(data.key_risks    || '[]'); } catch {}
  try { benefits = JSON.parse(data.key_benefits || '[]'); } catch {}

  const riskEl = document.getElementById('res-risks');
  const benEl  = document.getElementById('res-benefits');
  riskEl.innerHTML    = risks.map(r    => `<li>${r}</li>`).join('') || '<li>No data</li>';
  benEl.innerHTML     = benefits.map(b => `<li>${b}</li>`).join('') || '<li>No data</li>';

  document.getElementById('result-section').classList.add('show');
}

// ── submit proposal ───────────────────────────────────────────────────────
window.doSubmit = async function() {
  const title = document.getElementById('f-title').value.trim();
  const desc  = document.getElementById('f-desc').value.trim();

  if (title.length < 5)  { log('submit-log','Title must be at least 5 characters','err'); return; }
  if (desc.length  < 20) { log('submit-log','Description must be at least 20 characters','err'); return; }
  if (title.length > 200)  { log('submit-log','Title too long (max 200)','err'); return; }
  if (desc.length  > 5000) { log('submit-log','Description too long (max 5000)','err'); return; }

  const btn = document.getElementById('submit-btn');
  btn.disabled = true;
  btn.innerHTML = '<span style="display:inline-block;width:12px;height:12px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite"></span> Scoring...';

  document.getElementById('result-section').classList.remove('show');
  log('submit-log','Sending proposal to GenLayer validators...','info');
  startProgress();

  try {
    await writeContract('submit_proposal', [title, desc]);
    endProgress();

    // fetch the newly created proposal
    const stats = await readContract('get_stats');
    const total = Number(stats.total || 0);
    const newId = 'PROP-' + String(total).padStart(4, '0');
    log('submit-log', `Transaction finalized · ID: ${newId}`, 'ok');

    const data = await readContract('get_proposal', [newId]);
    if (data && data.id) {
      renderResult(data);
      log('submit-log', `Recommendation: ${data.recommendation} · Quorum: ${data.required_quorum}%`, 'ok');
      loadStats();
      loadSidebarHistory();
    } else {
      log('submit-log','Could not read proposal data — try lookup panel','err');
    }
  } catch(e) {
    endProgress();
    log('submit-log', 'Error: ' + (e?.shortMessage || e?.message || String(e)), 'err');
  }

  btn.disabled = false;
  btn.innerHTML = 'Score Proposal →';
};

// ── load history table ─────────────────────────────────────────────────────
window.loadHistory = async function() {
  log('history-log','Fetching all proposals...','info');
  const body = document.getElementById('history-body');
  try {
    const list = await readContract('list_proposals');
    if (!list || list.length === 0) {
      body.innerHTML = `
        <div class="empty-state">
          <div class="empty-icon">○</div>
          <div class="empty-title">No proposals yet</div>
          <div class="empty-sub">Submit the first proposal to get started</div>
        </div>`;
      log('history-log','No proposals found','info');
      return;
    }
    const rows = list.map(p => `
      <tr>
        <td class="table-id">${p.id}</td>
        <td>${p.title}</td>
        <td><span class="table-rec ${p.recommendation}">${p.recommendation}</span></td>
        <td style="font-family:var(--mono)">${p.risk_score}</td>
        <td style="font-family:var(--mono)">${p.benefit_score}</td>
        <td style="font-family:var(--mono)">${p.required_quorum}%</td>
        <td>
          <a class="table-link" href="javascript:void(0)"
             onclick="quickLookup('${p.id}')">View →</a>
        </td>
      </tr>`).join('');
    body.innerHTML = `
      <table class="proposal-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Recommendation</th>
            <th>Risk</th>
            <th>Benefit</th>
            <th>Quorum</th>
            <th></th>
          </tr>
        </thead>
        <tbody>${rows}</tbody>
      </table>`;
    log('history-log',`Loaded ${list.length} proposals`,'ok');
  } catch(e) {
    log('history-log','Error: ' + (e?.shortMessage || e?.message || String(e)),'err');
  }
};

window.quickLookup = function(id) {
  document.getElementById('lookup-id').value = id;
  const btn = document.querySelector('[onclick="nav(\'lookup\',this)"]');
  nav('lookup', btn);
  doLookup();
};

// ── lookup by id ─────────────────────────────────────────────────────────
window.doLookup = async function() {
  const id = document.getElementById('lookup-id').value.trim().toUpperCase();
  if (!id) return;
  log('lookup-log', `get_proposal(${id})...`, 'info');
  document.getElementById('lookup-result').style.display = 'none';
  try {
    const data = await readContract('get_proposal', [id]);
    if (!data || !data.id) {
      log('lookup-log', 'Proposal not found', 'err');
      return;
    }
    document.getElementById('lu-pid').textContent     = data.id;
    document.getElementById('lu-title').textContent   = data.title;
    document.getElementById('lu-proposer').textContent= data.proposer;
    document.getElementById('lu-created').textContent = data.created_at?.slice(0,19).replace('T',' ') || '—';
    document.getElementById('lu-risk').textContent    = data.risk_score + ' / 100';
    document.getElementById('lu-benefit').textContent = data.benefit_score + ' / 100';
    document.getElementById('lu-quorum').textContent  = data.required_quorum + '%';
    document.getElementById('lu-rec2').textContent    = data.recommendation;
    document.getElementById('lu-analysis').textContent= data.analysis || '—';
    document.getElementById('lu-desc').textContent    = data.description || '—';

    const rec = data.recommendation;
    const recEl = document.getElementById('lu-rec');
    recEl.textContent = rec;
    recEl.className   = 'rec-badge rec-' + rec;

    let risks = [], benefits = [];
    try { risks    = JSON.parse(data.key_risks    || '[]'); } catch {}
    try { benefits = JSON.parse(data.key_benefits || '[]'); } catch {}
    document.getElementById('lu-risks').innerHTML    = risks.map(r    => `<li>${r}</li>`).join('') || '<li>—</li>';
    document.getElementById('lu-benefits').innerHTML = benefits.map(b => `<li>${b}</li>`).join('') || '<li>—</li>';

    document.getElementById('lookup-result').style.display = 'block';
    log('lookup-log', 'Loaded · Recommendation: ' + data.recommendation, 'ok');
  } catch(e) {
    log('lookup-log', 'Error: ' + (e?.shortMessage || e?.message || String(e)), 'err');
  }
};

// ── stats ─────────────────────────────────────────────────────────────────
async function loadStats() {
  try {
    const s = await readContract('get_stats');
    document.getElementById('stat-total').textContent    = s.total    ?? '—';
    document.getElementById('stat-accepted').textContent = s.accepted ?? '—';
    document.getElementById('stat-revised').textContent  = s.revised  ?? '—';
    document.getElementById('stat-rejected').textContent = s.rejected ?? '—';
    document.getElementById('stat-dao').textContent      = s.dao_name ?? '—';
  } catch {}
}

async function loadSidebarHistory() {
  try {
    const list = await readContract('list_proposals');
    const el = document.getElementById('sidebar-history');
    if (!list || list.length === 0) {
      el.innerHTML = '<div style="font-size:11px;color:#333;padding:8px 10px;font-family:var(--mono)">No proposals yet</div>';
      return;
    }
    // show last 6
    const recent = list.slice(-6).reverse();
    el.innerHTML = recent.map(p => `
      <div class="history-item" onclick="quickLookup('${p.id}')">
        <span class="history-dot ${p.recommendation}"></span>
        <div>
          <div class="history-title">${p.title}</div>
          <div class="history-meta">${p.id} · ${p.recommendation}</div>
        </div>
      </div>`).join('');
  } catch {}
}

// ── fill example ──────────────────────────────────────────────────────────
